# .env.example — SAFE TO COMMIT
# Copy this to .env and fill in real values before running locally.
# Never commit .env — it is in .gitignore.

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=hedge_user
POSTGRES_PASSWORD=CHANGE_ME_generate_with_openssl_rand_hex_32
POSTGRES_DB=hedge_db
DATABASE_URL=postgresql+asyncpg://hedge_user:CHANGE_ME@localhost:5432/hedge_db

# ── Application secrets ───────────────────────────────────────────────────────
# Generate: openssl rand -hex 32
JWT_SECRET_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ── n8n ───────────────────────────────────────────────────────────────────────
# Generate: openssl rand -hex 32 (different from JWT_SECRET_KEY)
N8N_WEBHOOK_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32
N8N_ENCRYPTION_KEY=CHANGE_ME_exactly_32_chars_xxxxxxxxxx
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=CHANGE_ME
N8N_INTERNAL_URL=http://hedge-n8n:5678
N8N_TRIGGER_PATH=/webhook/fuel-hedge-trigger

# ── External APIs (optional — platform works without these) ──────────────────
EIA_API_KEY=OPTIONAL_get_free_key_at_eia.gov
OPENAI_API_KEY=OPTIONAL_sk-your-key-here

# ── Frontend ──────────────────────────────────────────────────────────────────
FRONTEND_ORIGIN=http://localhost:5173
VITE_API_BASE_URL=http://localhost:8000

# ── Environment ───────────────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://hedge-redis:6379/0
