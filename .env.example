# .env.example — SAFE TO COMMIT
# Copy this to .env and fill in real values before running locally.
# Never commit .env — it is in .gitignore.

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=hedge_user
POSTGRES_PASSWORD=CHANGE_ME_generate_with_openssl_rand_hex_32
POSTGRES_DB=hedge_db
DATABASE_URL=postgresql+asyncpg://hedge_user:CHANGE_ME@localhost:5432/hedge_db

# ── Application secrets ───────────────────────────────────────────────────────
# Generate: openssl rand -hex 32
JWT_SECRET_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ── n8n ───────────────────────────────────────────────────────────────────────
# Generate: openssl rand -hex 32 (different from JWT_SECRET_KEY)
N8N_WEBHOOK_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32
N8N_ENCRYPTION_KEY=CHANGE_ME_exactly_32_chars_xxxxxxxxxx
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=CHANGE_ME
N8N_INTERNAL_URL=http://hedge-n8n:5678
N8N_TRIGGER_PATH=/webhook/fuel-hedge-trigger
N8N_TRIGGER_URL=http://hedge-n8n:5678/webhook/fuel-hedge-trigger
N8N_DEMAND_STRATEGY_URL=http://hedge-n8n:5678/webhook/demand-strategy-advisor
N8N_REQUEST_TIMEOUT_SECONDS=20
N8N_REQUEST_MAX_RETRIES=2
N8N_REQUEST_RETRY_BACKOFF_SECONDS=1.5

# ── External APIs (optional — platform works without these) ──────────────────
EIA_API_KEY=OPTIONAL_get_free_key_at_eia.gov

# ── Live Price Feed ───────────────────────────────────────────────────────────
# true  → fetches real prices from Yahoo Finance (HO=F, BZ=F, CL=F + crack spread)
# false → runs GBM price simulation (no API keys needed, always works)
USE_LIVE_FEED=true
USE_YAHOO_FINANCE=true
USE_SIMULATION_FALLBACK=true
# How often to fetch fresh prices from Yahoo (seconds). 300 = every 5 minutes.
# The SSE stream still ticks every 2 seconds between fetches (animated with GBM).
YAHOO_FINANCE_UPDATE_INTERVAL=300
YAHOO_FINANCE_CACHE_TTL=300
MAX_YAHOO_REQUESTS_PER_HOUR=100

OPENAI_API_KEY=OPTIONAL_sk-your-key-here

# ── Frontend ──────────────────────────────────────────────────────────────────
FRONTEND_ORIGIN=http://localhost:5173
VITE_API_BASE_URL=http://localhost:8000

# ── Environment ───────────────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO
REPORTING_ENTITY_NAME=Airline Operations Ltd
REPORTING_CURRENCY=USD
IFRS9_REPORT_V2=true
SCHEDULER_ENABLED=true
SCHEDULER_TIMEZONE=UTC
SCHEDULER_DAILY_HOUR=0
SCHEDULER_DAILY_MINUTE=0
SCHEDULER_MISFIRE_GRACE_SECONDS=21600
SCHEDULER_CATCHUP_ON_STARTUP=true
# LSTM/TensorFlow (heavy RAM). Omit or false = ARIMA + XGBoost only (default).
ENABLE_LSTM_INFERENCE=false


# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://hedge-redis:6379/0
